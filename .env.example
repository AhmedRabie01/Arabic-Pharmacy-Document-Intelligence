APP_ENV=local
DEBUG=true

DOCUMENT_AI_PROVIDER=auto
PRIMARY_PROVIDER=paddleocr
FALLBACK_PROVIDER=chandra_ollama
ENABLE_FALLBACK=true
FALLBACK_CONFIDENCE_THRESHOLD=0.75

OCR_LANGUAGE=ar
OCR_CONFIDENCE_THRESHOLD=0.70
OCR_USE_ANGLE_CLS=true
OCR_USE_PREPROCESSED_IMAGES=true

PDF_RENDER_DPI=300
PREPROCESS_RESIZE_WIDTH=1600
PREPROCESS_GRAYSCALE=true
PREPROCESS_DENOISE=true
PREPROCESS_THRESHOLD=true

CHANDRA_MODEL=fredrezones55/chandra-ocr-2:patch
CHANDRA_BASE_URL=http://localhost:11434
CHANDRA_TIMEOUT_SECONDS=600
CHANDRA_NUM_PREDICT=800
CHANDRA_TEMPERATURE=0
ENABLE_CHANDRA_CACHE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=120
OPENAI_IMAGE_DETAIL=high
ENABLE_OPENAI_CACHE=true

DATABASE_URL=sqlite:///./invoice_ocr.db

SIGNATURE_YOLO_MODEL_PATH=models/signature_yolo/best.pt
SIGNATURE_YOLO_CONFIDENCE_THRESHOLD=0.25
SIGNATURE_YOLO_USE_HF_DEFAULT=true
SIGNATURE_YOLO_HF_REPO_ID=tech4humans/yolov8s-signature-detector
SIGNATURE_YOLO_HF_FILENAME=yolov8s.pt
SIGNATURE_YOLO_HF_FALLBACK_REPO_ID=ori-ron/yolov8s-signature-detector
SIGNATURE_YOLO_HF_FALLBACK_FILENAME=yolov8s.pt
